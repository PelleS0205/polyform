{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "polyform-tools": ["src/index.ts"],
      "polyform-tools/*": ["src/*"]
    }
  },
  "include": ["src/**/*"]
}
