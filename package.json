{
  "name": "polyform-tools",
  "version": "0.2.1",
  "type": "module",
  "description": "A minimalist data conversion library for text and binary formats.",
  "license": "GPL-3.0-or-later OR LicenseRef-Commercial",
  "main": ".dist/core/index.mjs",
  "types": ".dist/core/index.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core/index.mjs"
    },
    "./formats/json": {
      "types": "./dist/formats/json.d.mts",
      "import": "./dist/formats/json.mjs"
    },
    "./formats/yaml": {
      "types": "./dist/formats/yaml.d.mts",
      "import": "./dist/formats/yaml.mjs"
    },
    "./formats/cbor": {
      "types": "./dist/formats/cbor.d.mts",
      "import": "./dist/formats/cbor.mjs"
    },
    "./formats/csv": {
      "types": "./dist/formats/csv.d.mts",
      "import": "./dist/formats/csv.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "data-conversion",
    "binary-parser",
    "text-encoder",
    "serialization",
    "deserialization",
    "uint8array",
    "arraybuffer",
    "buffer-utils",
    "codec",
    "minimalist",
    "zero-dependency",
    "lightweight",
    "isomorphic",
    "typescript"
  ],
  "author": "Pelle Stormark",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.2",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "cbor2": "^2.3.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "yaml": "^2.9.0"
  }
}
